# Test materials — large files, not for version control
Posey Test Materials/
TestMaterials/

# API config — contains token, machine-local
tools/.posey_api_config.json
tools/.posey_api_config.*.json

# Xcode
*.xcuserstate
xcuserdata/
DerivedData/
*.moved-aside
*.pbxuser
*.perspectivev3

# Build output
/tmp/PoseyDeviceDerived/
*.ipa

# Stray SQLite artifacts (e.g. a default-path DatabaseManager() created during
# a test/build run dropping posey.sqlite into the source tree). Real app DBs
# live in Application Support, never in the repo.
*.sqlite
*.sqlite-wal
*.sqlite-shm

# macOS
.DS_Store
__pycache__/

# Claude Code session state (per-machine, scheduled tasks, local prefs)
.claude/

# Internal QA evidence, icon drafts.
Art/

# App Store submission materials — entirely private.
submission/

# Internal development tools — local-API test runner, RAG harnesses,
# antenna config, corpus generators. Local-only.
tools/

# Internal docs — local-only, tracked by the separate .posey-docs-git repo,
# never pushed to GitHub. See tools/docs.sh for the wrapper.
CLAUDE.md
HISTORY.md
NEXT.md
docs-internal/
.posey-docs-git/

# Derived active-task pointer, regenerated from MANDATE_QUEUE.md by tools/mandate.sh.
# Scratch view, not a record — never commit it. Source of truth is the queue.
MANDATE.md
